{
    "version": 29,
    "settings": {
        "mpv": {
            "path": "mpv",
            "extra_flags": [
                "--vo=gpu-next",
                "--fullscreen"
            ],
            "test_video_url": "http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4"
        },
        "connections": {
            "version": 1,
            "active": "",
            "items": []
        },
        "connection_state": {
            "version": 1,
            "scopes": {}
        },
        "input_bindings": {
            "schema": 1,
            "keyboard": {},
            "gamepad": {}
        },
        "playback": {
            "completion_threshold": 90,
            "autoplay_next_episode": true,
            "autoplay_countdown_seconds": 10,
            "auto_skip_intro": false,
            "auto_skip_outro": false,
            "audio_delay": 0,
            "playback_volume": 100,
            "playback_muted": false,
            "skip_button_auto_hide_seconds": 6,
            "theme_song_volume": 0,
            "theme_song_loop": false,
            "ui_sounds_enabled": true,
            "ui_sounds_volume": 3,
            "performance_mode_enabled": false
        },
        "video": {
            "enable_framerate_matching": false,
            "framerate_match_delay": 1,
            "enable_hdr": false,
            "linux_refresh_rate_command": "xrandr --output HDMI-1 --rate {RATE}",
            "linux_hdr_command": "",
            "windows_custom_hdr_command": ""
        },
        "cache": {
            "image_cache_size_mb": 500,
            "rounded_image_mode": "auto",
            "rounded_preprocess_enabled": true
        },
        "ui": {
            "backdrop_rotation_interval": 30000,
            "launch_in_fullscreen": false,
            "ui_animations_enabled": true,
            "screensaver": {
                "enabled": false,
                "mode": "libraryBackdrops",
                "timeout_seconds": 300
            }
        },
        "manualDpiScaleOverride": 1.0,
        "mpv_profiles": {
            "Low Quality": {
                "hwdec_enabled": true,
                "hwdec_method": "auto-safe",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "auto",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=fast"
                ]
            },
            "Medium Quality": {
                "hwdec_enabled": true,
                "hwdec_method": "auto-safe",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "auto",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality"
                ]
            },
            "High Quality": {
                "hwdec_enabled": true,
                "hwdec_method": "auto-safe",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "auto",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality",
                    "--glsl-shaders-append=~~/shaders/FSRCNNX_x2_8-0-4-1.glsl",
                    "--scale=ewa_lanczos",
                    "--glsl-shaders-append=~~/shaders/KrigBilateral.glsl",
                    "--cscale=ewa_lanczos",
                    "--glsl-shaders-append=~~/shaders/SSimDownscaler.glsl",
                    "--dscale=mitchell",
                    "--linear-downscaling=no",
                    "--correct-downscaling=yes"
                ]
            },
            "ArtCNN": {
                "hwdec_enabled": false,
                "hwdec_method": "no",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "vulkan",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality",
                    "--sub-fonts-dir=~~/fonts",
                    "--sub-ass-override=no",
                    "--sub-font=Gandhi Sans Bold",
                    "--sub-font-size=48",
                    "--sub-color=#FFFFFF",
                    "--sub-border-size=2.4",
                    "--sub-border-color=#FF000000",
                    "--sub-shadow-color=#A0000000",
                    "--sub-shadow-offset=0.75",
                    "--sub-ass=yes",
                    "--sub-bold=no",
                    "--sub-ass-style-overrides=WrapStyle=0,Kerning=yes,Spacing=0,MarginL=200,MarginR=200,MarginV=74,Outline=3.6,Shadow=1.5",
                    "--blend-subtitles=video",
                    "--secondary-sub-ass-override=yes",
                    "--glsl-shaders-append=~~/shaders/ArtCNN_C4F16.glsl",
                    "--deband=no"
                ]
            },
            "ArtCNN-Deband": {
                "hwdec_enabled": false,
                "hwdec_method": "no",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "vulkan",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality",
                    "--sub-fonts-dir=~~/fonts",
                    "--sub-ass-override=no",
                    "--sub-font=Gandhi Sans Bold",
                    "--sub-font-size=48",
                    "--sub-color=#FFFFFF",
                    "--sub-border-size=2.4",
                    "--sub-border-color=#FF000000",
                    "--sub-shadow-color=#A0000000",
                    "--sub-shadow-offset=0.75",
                    "--sub-ass=yes",
                    "--sub-bold=no",
                    "--sub-ass-style-overrides=WrapStyle=0,Kerning=yes,Spacing=0,MarginL=200,MarginR=200,MarginV=74,Outline=3.6,Shadow=1.5",
                    "--blend-subtitles=video",
                    "--secondary-sub-ass-override=yes",
                    "--glsl-shaders-append=~~/shaders/ArtCNN_C4F16.glsl",
                    "--deband=yes",
                    "--deband-iterations=4",
                    "--deband-threshold=48",
                    "--deband-range=64",
                    "--deband-grain=12"
                ]
            },
            "nnedi3": {
                "hwdec_enabled": false,
                "hwdec_method": "no",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "vulkan",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality",
                    "--sub-fonts-dir=~~/fonts",
                    "--sub-ass-override=no",
                    "--sub-font=Gandhi Sans Bold",
                    "--sub-font-size=48",
                    "--sub-color=#FFFFFF",
                    "--sub-border-size=2.4",
                    "--sub-border-color=#FF000000",
                    "--sub-shadow-color=#A0000000",
                    "--sub-shadow-offset=0.75",
                    "--sub-ass=yes",
                    "--sub-bold=no",
                    "--sub-ass-style-overrides=WrapStyle=0,Kerning=yes,Spacing=0,MarginL=200,MarginR=200,MarginV=74,Outline=3.6,Shadow=1.5",
                    "--blend-subtitles=video",
                    "--secondary-sub-ass-override=yes",
                    "--glsl-shaders-append=~~/shaders/nnedi3-nns32-win8x6.hook",
                    "--deband=no"
                ]
            },
            "nnedi3-deband": {
                "hwdec_enabled": false,
                "hwdec_method": "no",
                "deinterlace": false,
                "deinterlace_method": "",
                "video_output": "gpu-next",
                "interpolation": false,
                "windows_render_api": "vulkan",
                "hdr_metadata_mode": "target",
                "windows_10bit_output": false,
                "extra_args": [
                    "--fullscreen",
                    "--profile=high-quality",
                    "--sub-fonts-dir=~~/fonts",
                    "--sub-ass-override=no",
                    "--sub-font=Gandhi Sans Bold",
                    "--sub-font-size=48",
                    "--sub-color=#FFFFFF",
                    "--sub-border-size=2.4",
                    "--sub-border-color=#FF000000",
                    "--sub-shadow-color=#A0000000",
                    "--sub-shadow-offset=0.75",
                    "--sub-ass=yes",
                    "--sub-bold=no",
                    "--sub-ass-style-overrides=WrapStyle=0,Kerning=yes,Spacing=0,MarginL=200,MarginR=200,MarginV=74,Outline=3.6,Shadow=1.5",
                    "--blend-subtitles=video",
                    "--secondary-sub-ass-override=yes",
                    "--glsl-shaders-append=~~/shaders/nnedi3-nns32-win8x6.hook",
                    "--deband=yes",
                    "--deband-iterations=4",
                    "--deband-threshold=48",
                    "--deband-range=64",
                    "--deband-grain=12"
