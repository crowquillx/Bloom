        "default_profile": "Medium Quality",
        "seerr": {
            "base_url": "",
            "api_key": ""
        },
        "media_segments": {
            "external_providers_enabled": true,
            "provider_order": [
                "theintrodb",
                "introdb"
            ]
        }
    }
}
